<!--
  HYPOTHETICAL RECONSTRUCTION — not the original HomeView.xaml.
  HomeView.g.cs has an empty Connect() switch — no named fields, no event
  handlers — so the original landing page is essentially a static layout.
-->
<UserControl x:Class="Review_Reminder.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Review_Reminder.MVVM.ViewModel"
             d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="#272537">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Greeting}"
                   Foreground="White"
                   FontSize="36"
                   FontWeight="Bold" />

        <TextBlock Grid.Row="1"
                   Text="{Binding Tagline}"
                   Foreground="#B6B4C8"
                   FontSize="14"
                   Margin="0,8,0,24" />

        <StackPanel Grid.Row="2" Orientation="Vertical">
            <Button Content="Add a study item"
                    Width="200"
                    Height="40"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12" />
            <Button Content="View today's reviews"
                    Width="200"
                    Height="40"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </Grid>
</UserControl>
