<UserControl x:Class="Review_Reminder.MVVM.View.InformationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Review_Reminder.MVVM.ViewModel"
             d:DataContext="{d:DesignInstance Type=vm:InformationViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="#272537">
    <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="{Binding Title}"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,16" />
            <TextBlock Text="{Binding Intro}"
                       Foreground="#D6D4E8"
                       FontSize="14"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding HowItWorks}"
                       Foreground="#D6D4E8"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,16,0,8" />
            <ItemsControl ItemsSource="{Binding Schedule}" Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Foreground="White"
                                   Margin="0,2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
