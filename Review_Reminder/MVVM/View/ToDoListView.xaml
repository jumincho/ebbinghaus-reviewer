<UserControl x:Class="Review_Reminder.MVVM.View.ToDoListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Review_Reminder.MVVM.ViewModel"
             d:DataContext="{d:DesignInstance Type=vm:ToDoListViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="#272537">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="To Do"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,16" />

        <!-- Existing items -->
        <ListBox x:Name="PageListBox"
                 Grid.Row="1"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
                 MouseDoubleClick="listclicked"
                 Background="#1F1D2B"
                 Foreground="White"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="8,4">
                        <TextBlock Text="{Binding Title}" Foreground="White" />
                        <TextBlock Text="  •  next: " Foreground="#888" />
                        <TextBlock Text="{Binding NextReviewTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                   Foreground="#AAA" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Add form -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="inputtextbox"
                     Grid.Column="0"
                     Text="{Binding DraftTitle, UpdateSourceTrigger=PropertyChanged}"
                     Height="36"
                     VerticalContentAlignment="Center"
                     Padding="8,0" />

            <Button Grid.Column="1"
                    Content="Add"
                    Width="96"
                    Height="36"
                    Margin="8,0,0,0"
                    Click="btnclick"
                    Command="{Binding AddItemCommand}" />
        </Grid>
    </Grid>
</UserControl>
