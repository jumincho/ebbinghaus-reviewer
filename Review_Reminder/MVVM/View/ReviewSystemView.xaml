<UserControl x:Class="Review_Reminder.MVVM.View.ReviewSystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Review_Reminder.MVVM.ViewModel"
             d:DataContext="{d:DesignInstance Type=vm:ReviewSystemViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="#272537">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Today's reviews"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,16" />

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding TodaysReviews}"
                  AutoGenerateColumns="False"
                  Background="#1F1D2B"
                  Foreground="White"
                  BorderThickness="0"
                  IsReadOnly="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="Due"
                                    Binding="{Binding DueAt, StringFormat='{}{0:HH:mm}'}"
                                    Width="100" />
                <DataGridTemplateColumn Header="" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Done"
                                    Command="{Binding DataContext.AcknowledgeCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2"
                Content="Refresh"
                Width="120"
                Height="32"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Command="{Binding RefreshCommand}" />
    </Grid>
</UserControl>
